# Prompt for a keypress to continue. Customise prompt with $*
function pause {
  >/dev/tty printf '%s' "${*:-Press any key to continue... }"
  if [[ ${BASH_VERSION:-} ]]; then
    </dev/tty read -rsn1
  else  # zsh
    read -krs  # Use -u0 to read from STDIN
  fi
  printf '\n'
}


# Define pbcopy / pbpaste for non-Mac
if ! is_mac; then
  function pbcopy { sed -Ez 's/^\n+//; s/\n+$//' | xclip -selection clipboard -in; }
  function pbcopy_clean { xclip -selection clipboard -in; }
  function pbpaste { xclip -selection clipboard -out; }
  export_function pbcopy pbcopy_clean pbpaste
fi

# rm_from_path_var — remove all occurrences of a directory from PATH
#
# Usage: rm_from_path_var <dir>
#   Removes every exact occurrence of <dir> from PATH.
#   PATH entries are colon-delimited; only full-segment matches are removed.
#   Partial matches (e.g. removing /bin matching /usr/bin) never happen.
#   An empty PATH after removal is allowed.
#
# Return codes:
#   0  — removed successfully (PATH may be empty)
#   1  — dir not present in PATH (no-op)
#   2  — usage error: empty arg, arg contains colon/newline, or arg is not absolute
#
# Security guarantees:
#   - Glob metacharacters in <dir> are treated as literal characters, never as patterns
#   - Only full PATH segment matches are removed (no partial/substring matches)
#   - Colons and newlines in <dir> are rejected (they corrupt PATH structure)
#   - No leading or trailing colons are introduced in the result
#   - POSIX // special-case is handled correctly
#
# Implementation: Split PATH on colons to null-delimited records, filter with
# grep -zFxv (fixed-string, exact-record, null-delimited, invert-match), then
# rejoin.  This is glob-safe (grep -F = literal), preserves empty PATH segments
# (each colon produces a null record), and produces no leading/trailing colons
# (paste -sd: only inserts separators between records).
rm_from_path_var() {
    local dir="$1"

    # ── validate input ──────────────────────────────────────────────
    [[ -z "$dir" ]] && return 2

    # Reject colons — they are the PATH delimiter and make segment
    # matching ambiguous.  Reject newlines — they corrupt PATH silently.
    [[ "$dir" == *[:$'\n']* ]] && return 2

    # Reject non-absolute paths — PATH entries are always absolute.
    # This prevents accidental partial-string matches on relative names.
    [[ "$dir" != /* ]] && return 2

    # ── normalise the directory path ────────────────────────────────
    # Preserve caller's extglob state to avoid leaking or overrestoring.
    local _extglob_was_on=0
    shopt -q extglob && _extglob_was_on=1
    shopt -s extglob

    # POSIX special case: leading // is meaningful on some systems (Distributed
    # Name Service per POSIX.1-2017 §4.13).  Preserve exactly two leading slashes
    # when the third character is not also a slash.
    if [[ "$dir" == "//"* && "${dir:2:1}" != "/" ]]; then
        local body="${dir:2}"
        body="${body//+(\/)/\/}"
        body="${body%/}"
        [[ -z "$body" ]] && dir="//" || dir="//${body}"
    else
        dir="${dir//+(\/)/\/}"
        dir="${dir%/}"
        [[ -z "$dir" ]] && dir="/"
    fi

    # Restore extglob to its prior state
    [[ "$_extglob_was_on" -eq 0 ]] && shopt -u extglob

    # ── bail if not present ─────────────────────────────────────────
    [[ ":${PATH}:" != *":${dir}:"* ]] && return 1

    # ── filter and rejoin ───────────────────────────────────────────
    # Convert colons to null-delimited records with tr, filter out exact
    # matches with grep -zFxv, rejoin with paste.  Empty PATH segments
    # (consecutive colons) are preserved as empty null-delimited records.
    # Result preserves leading/trailing/empty segments — paste inserts ':'
    # between records including empty ones.
    PATH=$(printf '%s' "$PATH" | /usr/bin/tr ':' '\0' | /usr/bin/grep -zFxv -- "$dir" | /usr/bin/tr '\0' '\n' | /usr/bin/paste -sd ':')
}
